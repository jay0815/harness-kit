{
  "name": "@harness-kit/core",
  "version": "0.1.0",
  "description": "Coding agent harness - orchestrates multi-agent workflows with hard fact verification",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "harness-verify": "bin/harness-verify",
    "harness-telemetry": "bin/harness-telemetry"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/test-e2e-direct.ts",
    "pi": "pi"
  },
  "dependencies": {
    "@harness-kit/agent": "workspace:*",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@sinclair/typebox": "^0.34.0",
    "pi-kimi-coder": "^1.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^1.66.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
