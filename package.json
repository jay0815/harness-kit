{
  "name": "harness-kit",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --if-present --sort run build",
    "test": "pnpm -r --filter './packages/**' --if-present --sort run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:init": "oxlint --init",
    "fmt": "oxfmt packages package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "fmt:check": "oxfmt --check packages package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "fmt:init": "oxfmt --init",
    "typecheck": "pnpm -r --filter './packages/**' --if-present --sort run typecheck",
    "harness": "node packages/harness-agent/dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
